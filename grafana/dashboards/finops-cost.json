{
  "uid": "finops-cost",
  "title": "FinOps — Cost Overview",
  "tags": ["finops", "cost"],
  "timezone": "",
  "editable": true,
  "schemaVersion": 39,
  "version": 1,
  "refresh": "",
  "time": { "from": "now-30d", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total cost (30d, Amortized)",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2 }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "finops_pg" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(SUM(cost),0) AS \"Total\" FROM v_cost_by_type"
        }
      ]
    },
    {
      "id": 2,
      "type": "piechart",
      "title": "Cost by resource type",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": true },
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "finops_pg" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT resource_type AS metric, cost AS value FROM v_cost_by_type ORDER BY cost DESC"
        }
      ]
    },
    {
      "id": 3,
      "type": "barchart",
      "title": "Cost by region",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] },
      "options": {
        "orientation": "horizontal",
        "xField": "location",
        "legend": { "showLegend": false }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "finops_pg" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT location, cost FROM v_cost_by_region ORDER BY cost DESC"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Daily cost trend (Amortized)",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "finops_pg" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT usage_date::timestamp AS time, SUM(cost) AS \"Amortized cost\" FROM cost_snapshots WHERE cost_type = 'Amortized' GROUP BY usage_date ORDER BY 1"
        }
      ]
    },
    {
      "id": 5,
      "type": "table",
      "title": "Top resources by cost (30d)",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "cost" }, "properties": [ { "id": "unit", "value": "currencyUSD" }, { "id": "custom.cellOptions", "value": { "type": "gauge" } } ] }
        ]
      },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "cost", "desc": true } ] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "finops_pg" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT resource_id, resource_type, location, resource_group, cost FROM v_cost_by_resource ORDER BY cost DESC LIMIT 25"
        }
      ]
    }
  ]
}
