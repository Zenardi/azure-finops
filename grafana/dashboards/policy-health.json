{
  "uid": "finops-policy-health",
  "title": "FinOps — Policy Health & Compliance",
  "tags": ["finops", "governance", "policy"],
  "timezone": "",
  "editable": true,
  "schemaVersion": 39,
  "version": 1,
  "refresh": "",
  "time": { "from": "now-30d", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Avg success rate",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 1, "min": 0, "max": 1, "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none" },
      "targets": [
        { "refId": "A", "datasource": { "type": "postgres", "uid": "finops_pg" }, "editorMode": "code", "format": "table", "rawQuery": true,
          "rawSql": "SELECT COALESCE(ROUND(AVG(success_rate), 4), 0) AS \"Success rate\" FROM v_policy_health" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Policies executed",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none" },
      "targets": [
        { "refId": "A", "datasource": { "type": "postgres", "uid": "finops_pg" }, "editorMode": "code", "format": "table", "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS \"Policies\" FROM v_policy_health" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total resources matched",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "orange" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none" },
      "targets": [
        { "refId": "A", "datasource": { "type": "postgres", "uid": "finops_pg" }, "editorMode": "code", "format": "table", "rawQuery": true,
          "rawSql": "SELECT COALESCE(SUM(total_matches), 0) AS \"Matches\" FROM v_policy_health" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Resources matched over time (by policy)",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "showPoints": "always", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "postgres", "uid": "finops_pg" }, "editorMode": "code", "format": "time_series", "rawQuery": true,
          "rawSql": "SELECT e.started_at AS time, p.name AS metric, e.resources_matched AS value FROM policy_executions e JOIN policies p ON e.policy_id = p.id WHERE e.started_at IS NOT NULL ORDER BY e.started_at" }
      ]
    },
    {
      "id": 5,
      "type": "table",
      "title": "Policy health (per policy, all subscriptions)",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "success_rate" }, "properties": [ { "id": "unit", "value": "percentunit" }, { "id": "custom.cellOptions", "value": { "type": "gauge" } }, { "id": "min", "value": 0 }, { "id": "max", "value": 1 } ] }
        ]
      },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "success_rate", "desc": false } ] },
      "targets": [
        { "refId": "A", "datasource": { "type": "postgres", "uid": "finops_pg" }, "editorMode": "code", "format": "table", "rawQuery": true,
          "rawSql": "SELECT policy_name, resource_type, total_executions, succeeded_executions, failed_executions, total_matches, subscriptions, success_rate, last_status, last_execution_at FROM v_policy_health ORDER BY last_execution_at DESC NULLS LAST" }
      ]
    },
    {
      "id": 6,
      "type": "table",
      "title": "Compliance by subscription",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "policy_name", "desc": false } ] },
      "targets": [
        { "refId": "A", "datasource": { "type": "postgres", "uid": "finops_pg" }, "editorMode": "code", "format": "table", "rawQuery": true,
          "rawSql": "SELECT policy_name, subscription_id, total_executions, succeeded_executions, total_matches, last_execution_at FROM v_policy_compliance ORDER BY policy_name, subscription_id" }
      ]
    }
  ]
}
