{
  "uid": "finops-execution-health",
  "title": "FinOps — Policy Execution Health",
  "tags": ["finops", "governance", "execution", "health"],
  "timezone": "",
  "editable": true,
  "schemaVersion": 39,
  "version": 1,
  "refresh": "",
  "time": { "from": "now-30d", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Avg success rate",
      "description": "Mean per-policy success rate. Zero when nothing has executed.",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 1, "min": 0, "max": 1, "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none" },
      "targets": [
        { "refId": "A", "datasource": { "type": "postgres", "uid": "finops_pg" }, "editorMode": "code", "format": "table", "rawQuery": true,
          "rawSql": "SELECT COALESCE(ROUND(AVG(success_rate), 4), 0) AS \"Success rate\" FROM v_execution_health" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Executions",
      "description": "Total recorded policy executions.",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none" },
      "targets": [
        { "refId": "A", "datasource": { "type": "postgres", "uid": "finops_pg" }, "editorMode": "code", "format": "table", "rawQuery": true,
          "rawSql": "SELECT COALESCE(SUM(total_executions), 0) AS \"Executions\" FROM v_execution_health" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Failed executions",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "red" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none" },
      "targets": [
        { "refId": "A", "datasource": { "type": "postgres", "uid": "finops_pg" }, "editorMode": "code", "format": "table", "rawQuery": true,
          "rawSql": "SELECT COALESCE(SUM(failed), 0) AS \"Failed\" FROM v_execution_health" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Avg duration",
      "description": "Mean per-policy execution duration (finished runs only).",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 2, "color": { "mode": "fixed", "fixedColor": "orange" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none" },
      "targets": [
        { "refId": "A", "datasource": { "type": "postgres", "uid": "finops_pg" }, "editorMode": "code", "format": "table", "rawQuery": true,
          "rawSql": "SELECT COALESCE(ROUND(AVG(avg_duration_seconds), 3), 0) AS \"Avg duration\" FROM v_execution_health" }
      ]
    },
    {
      "id": 5,
      "type": "bargauge",
      "title": "Success rate by policy",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "color": { "mode": "continuous-RdYlGr" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "displayMode": "gradient", "orientation": "horizontal", "showUnfilled": true },
      "targets": [
        { "refId": "A", "datasource": { "type": "postgres", "uid": "finops_pg" }, "editorMode": "code", "format": "table", "rawQuery": true,
          "rawSql": "SELECT policy_name, success_rate FROM v_execution_health ORDER BY success_rate ASC, policy_name ASC" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Execution duration over time (by policy)",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "showPoints": "always", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "postgres", "uid": "finops_pg" }, "editorMode": "code", "format": "time_series", "rawQuery": true,
          "rawSql": "SELECT e.started_at AS time, p.name AS metric, EXTRACT(EPOCH FROM (e.finished_at - e.started_at)) AS value FROM policy_executions e JOIN policies p ON e.policy_id = p.id WHERE e.finished_at IS NOT NULL ORDER BY e.started_at" }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Execution health (per policy)",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "success_rate" }, "properties": [ { "id": "unit", "value": "percentunit" }, { "id": "custom.cellOptions", "value": { "type": "gauge" } }, { "id": "min", "value": 0 }, { "id": "max", "value": 1 } ] },
          { "matcher": { "id": "byName", "options": "avg_duration_seconds" }, "properties": [ { "id": "unit", "value": "s" } ] },
          { "matcher": { "id": "byName", "options": "failed" }, "properties": [ { "id": "custom.cellOptions", "value": { "type": "color-background" } }, { "id": "color", "value": { "mode": "thresholds" } }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } } ] }
        ]
      },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "last_execution_at", "desc": true } ] },
      "targets": [
        { "refId": "A", "datasource": { "type": "postgres", "uid": "finops_pg" }, "editorMode": "code", "format": "table", "rawQuery": true,
          "rawSql": "SELECT policy_name, total_executions, succeeded, failed, success_rate, avg_duration_seconds, last_status, last_execution_at FROM v_execution_health ORDER BY last_execution_at DESC NULLS LAST" }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Execution health (per binding)",
      "datasource": { "type": "postgres", "uid": "finops_pg" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 23 },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "success_rate" }, "properties": [ { "id": "unit", "value": "percentunit" }, { "id": "custom.cellOptions", "value": { "type": "gauge" } }, { "id": "min", "value": 0 }, { "id": "max", "value": 1 } ] },
          { "matcher": { "id": "byName", "options": "avg_duration_seconds" }, "properties": [ { "id": "unit", "value": "s" } ] }
        ]
      },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "last_execution_at", "desc": true } ] },
      "targets": [
        { "refId": "A", "datasource": { "type": "postgres", "uid": "finops_pg" }, "editorMode": "code", "format": "table", "rawQuery": true,
          "rawSql": "SELECT binding_id, total_executions, succeeded, failed, success_rate, avg_duration_seconds, last_status, last_execution_at FROM v_execution_health_by_binding ORDER BY last_execution_at DESC NULLS LAST" }
      ]
    }
  ]
}
